{% extends "layout.jinja2" %}

{% block content %}
<div class="content">
  <h1>{{ title }}</h1>
  <h2>Honeycomb node</h2>

  <h3>Nodos disponibles</h3>
  <ul>
    {% for node, url in children %}
      <li>
        <a href="{{ url }}">{{ node.title }}</a> ({{ node.__name__ }})
      </li>
    {% else %}
      <li>Este es un nodo terminal</li>
    {% endfor %}
  </ul>

  <p>
    <!-- <a href="/editor?json=/panal-de-juegos/json">Abrir en editor</a> -->
  </p>
</div>
{% endblock content %}